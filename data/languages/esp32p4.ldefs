<language_definitions>

  <language processor="RISCV"
            endian="little"
            size="32"
            variant="ESP32-P4"
            version="1.0"
            slafile="esp32p4.sla"
            processorspec="RV32.pspec"
            id="RISCV:LE:32:ESP32-P4">
    <description>ESP32-P4 RISC-V 32-bit (RV32IMAFC + xesploop + xesppie)</description>
    <compiler name="gcc" spec="esp32p4.cspec" id="gcc"/>
    <external_name tool="DWARF.register.mapping.file" name="riscv32.dwarf"/>
    <external_name tool="gnu" name="riscv:rv32"/>
    <external_name tool="qemu" name="qemu-riscv32"/>
  </language>

</language_definitions>
